(defwindow tuxclock
	   :monitor 0
	   :class "tuxclock"
	   :geometry ( geometry
		       :width "100%"
		       :height "100%"
		       :anchor "center center")
	   :hexpand true
	   :vexpand true
	   :stacking "bg"

	   ;; (box :space-evenly false

	   (box 
	    :valign "center"
	    :halign "center"

	    :orientation "v"

	    :space-evenly false
	    :spacing 20

	    (clock)
	    )

	   ;; )
	   )

(defwidget clock []
	   (box
	    :class "time"
	    "${clock_}"
	    )
	   )
