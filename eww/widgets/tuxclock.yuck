(defwindow tuxclock
 :monitor 0
 :class "tuxclock"
 :geometry ( geometry
	 ;:x "20px"
	 ;; :y "20px"
	 :width "50%"
	 :anchor "center center"
	 )
 :hexpand true
 :vexpand true
 :stacking "bg"

 (box 
  :orientation "vertical"
  :space-evenly false
  :spacing 10
  ;; (image 
  ;;  :path "/home/salim_belkacem/3d wizard gifs/tux using computer transparent.gif"
  ;; )
  (clock)
 )
 )

 (defwidget clock []
  (box
   :class "time"
   "${clock_}"
  )
 )
