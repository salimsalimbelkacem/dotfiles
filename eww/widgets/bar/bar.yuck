(include "./widgets/bar/widgets.yuck")
(include "./widgets/bar/left.yuck")
(include "./widgets/bar/middle.yuck")
(include "./widgets/bar/right.yuck")

(defwidget bar []
	   (box :class "bar"
		(left) (middle) (right)))

(defwindow status_bar
	   :monitor 0
	   :geometry
	   (geometry :height "22px" :width "100%" :anchor "bottom center")

	   :reserve (struts :distance "30px" :side "bottom")
	   :stacking "bg"
	   :wm-ignore false
	   (bar)
	   ) 
